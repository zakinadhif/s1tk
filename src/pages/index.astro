---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const allTopics = await getCollection('topics');

// Group by subject then sort by order
const bySubject = allTopics.reduce<Record<string, typeof allTopics>>((acc, t) => {
  const subj = t.data.subject;
  if (!acc[subj]) acc[subj] = [];
  acc[subj].push(t);
  return acc;
}, {});
Object.values(bySubject).forEach(arr => arr.sort((a, b) => a.data.order - b.data.order));

// Group subjects by semester
const bySemester: Record<number, { subject: string; topics: typeof allTopics }[]> = {};
for (const [subject, topics] of Object.entries(bySubject)) {
  const sem = topics[0].data.semester;
  if (!bySemester[sem]) bySemester[sem] = [];
  bySemester[sem].push({ subject, topics });
}
const semesters = Object.keys(bySemester).map(Number).sort((a, b) => a - b);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function subjectLabel(slug: string) {
  return slug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
}

function typeLabel(t: string) {
  const map: Record<string, string> = {
    aktivitas: 'Aktivitas', materi: 'Materi', kuis: 'Kuis', praktikum: 'Praktikum', referensi: 'Referensi'
  };
  return map[t] ?? t;
}
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>S1TK Notebook — Kurikulum</title>
    <meta name="description" content="Digital lab notebook untuk mahasiswa S1 Teknik Komputer Universitas Telkom." />
  </head>
  <body>
    <header class="site-header">
      <a href="/">S1TK Notebook</a>
      <span class="header-sub">Prodi S1 Teknik Komputer — Fakultas Teknik Elektro — Universitas Telkom</span>
    </header>

    <main class="landing-main">
      <div class="landing-hero">
        <h1 class="landing-title">Lab Notebook Digital</h1>
        <p class="landing-tagline">Eksplorasi elektronika, pemrograman, dan sistem komputer — dengan simulasi interaktif, bukan hafalan rumus.</p>
      </div>

      <div class="curriculum-tree">
        {semesters.map(sem => (
          <section class="semester-section">
            <h2 class="semester-heading">
              <span class="semester-badge">Semester {sem}</span>
            </h2>
            {bySemester[sem].map(({ subject, topics }) => (
              <div class="subject-card">
                <div class="subject-card-header">
                  <div>
                    <a class="subject-title" href={`${base}/${subject}`}>{subjectLabel(subject)}</a>
                    <p class="subject-meta">
                      {topics[0].data.courseCode} &middot; {topics.length} topik
                    </p>
                  </div>
                  <a class="subject-overview-link" href={`${base}/${subject}`}>Lihat semua →</a>
                </div>
                <ul class="topic-list">
                  {topics.map(t => {
                    const slug = t.id.split('/').at(-1);
                    return (
                      <li class="topic-item">
                        <a href={`${base}/${subject}/${slug}`} class="topic-link">
                          <div class="topic-link-inner">
                            <span class="topic-order">{String(t.data.order).padStart(2, '0')}</span>
                            <div class="topic-info">
                              <span class="topic-title">{t.data.title}</span>
                              <span class="topic-summary">{t.data.summary}</span>
                            </div>
                            <div class="topic-meta-right">
                              {t.data.estimatedMinutes && (
                                <span class="topic-time">⏱ {t.data.estimatedMinutes}m</span>
                              )}
                              <span class="topic-type-badge">{typeLabel(t.data.type)}</span>
                            </div>
                          </div>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            ))}
          </section>
        ))}
      </div>
    </main>
  </body>
</html>

<style>
  body { min-height: 100vh; }

  .site-header {
    background: var(--color-binder);
    color: #fff;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .site-header a { color: #fff; text-decoration: none; font-weight: 600; font-size: 1.1rem; }
  .header-sub { opacity: 0.6; font-size: 0.82rem; }

  .landing-main { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }

  .landing-hero { margin-bottom: 2.5rem; text-align: center; }
  .landing-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-binder);
    margin: 0 0 0.5rem;
  }
  .landing-tagline {
    font-size: 1.1rem;
    color: var(--color-ink-muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .semester-section { margin-bottom: 2.5rem; }
  .semester-heading { margin: 0 0 1rem; }
  .semester-badge {
    display: inline-block;
    background: var(--color-binder);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-family: var(--font-mono);
  }

  .subject-card {
    background: var(--color-paper);
    border-radius: var(--radius);
    box-shadow: 0 1px 6px rgba(0,0,0,0.07);
    overflow: hidden;
    margin-bottom: 1rem;
  }
  .subject-card-header {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-grid);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .subject-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-binder);
    text-decoration: none;
  }
  .subject-title:hover { text-decoration: underline; }
  .subject-meta { margin: 0.15rem 0 0; font-size: 0.8rem; color: var(--color-ink-muted); font-family: var(--font-mono); }
  .subject-overview-link { font-size: 0.85rem; color: var(--color-accent); text-decoration: none; white-space: nowrap; }
  .subject-overview-link:hover { text-decoration: underline; }

  .topic-list { list-style: none; padding: 0; margin: 0; }
  .topic-item { border-bottom: 1px solid var(--color-grid); }
  .topic-item:last-child { border-bottom: none; }
  .topic-link { display: block; text-decoration: none; color: inherit; }
  .topic-link:hover .topic-link-inner { background: hsl(215 50% 97%); }
  .topic-link-inner {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    transition: background 0.12s;
  }
  .topic-order {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-ink-muted);
    min-width: 1.5rem;
    padding-top: 0.15rem;
  }
  .topic-info { flex: 1; min-width: 0; }
  .topic-title { display: block; font-weight: 600; font-size: 0.9rem; color: var(--color-ink); }
  .topic-summary { display: block; font-size: 0.8rem; color: var(--color-ink-muted); margin-top: 0.15rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .topic-meta-right { display: flex; flex-direction: column; align-items: flex-end; gap: 0.2rem; }
  .topic-time { font-size: 0.75rem; color: var(--color-ink-muted); font-family: var(--font-mono); white-space: nowrap; }
  .topic-type-badge {
    font-size: 0.7rem;
    padding: 0.1rem 0.4rem;
    border-radius: 999px;
    background: var(--color-grid);
    color: var(--color-ink-muted);
    font-family: var(--font-mono);
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .topic-meta-right { display: none; }
    .landing-title { font-size: 1.75rem; }
  }
</style>
